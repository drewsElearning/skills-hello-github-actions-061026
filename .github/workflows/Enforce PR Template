name: Enforce PR Template

on:
  pull_request:
    types: [opened, edited, synchronize]

permissions:
  contents: read
  pull-requests: read

jobs:
  validate-pr-template:
    runs-on: ubuntu-latest

    steps:
      - name: Check for PR template file
        id: check_template
        run: |
          if [ ! -f ".github/pull_request_template.md" ]; then
            echo "❌ Missing .github/pull_request_template.md"
            exit 1
          fi
          echo "✅ PR template exists"

      - name: Validate PR description is not empty/default
        run: |
          PR_BODY=$(jq -r '.pull_request.body' "$GITHUB_EVENT_PATH")

          if [ -z "$PR_BODY" ]; then
            echo "❌ PR description is empty"
            exit 1
          fi

          # Example validation: require at least 50 characters
          if [ ${#PR_BODY} -lt 50 ]; then
            echo "❌ PR description too short (must be >50 chars)"
            exit 1
          fi

          echo "✅ PR description looks good"
